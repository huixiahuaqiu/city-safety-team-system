# 本机 Docker 预演 MinIO（数据目录 D:\Docker\data\minio）
#
# 1) 复制并改口令：
#    copy deploy\minio\.env.local.example deploy\minio\.env.local
# 2) 启动：
#    docker compose -f deploy/minio/docker-compose.yml --env-file deploy/minio/.env.local up -d
# 3) 初始化桶（PowerShell，需 tools\minio\mc.exe）：
#    见 init-bucket.sh；Windows 可用同等 mc 命令
# 4) 把 APP 密钥写入 123123/.env（SHARED_STORAGE_BACKEND=minio）
# 5) 控制台：http://127.0.0.1:9001  API：http://127.0.0.1:9000
#
# 停止：docker compose -f deploy/minio/docker-compose.yml --env-file deploy/minio/.env.local down

MINIO_ROOT_USER=citysafe_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_TO_16PLUS_CHARS
APP_ACCESS_KEY=citysafe_app
APP_SECRET_KEY=CHANGE_ME_APP_SECRET_16PLUS
MINIO_BUCKET=team-shared
MINIO_ENDPOINT=http://127.0.0.1:9000
