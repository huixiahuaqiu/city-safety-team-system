# 生产环境模板：复制到 /opt/citysafe/.env ，权限 600，属主 appsvc。
# 禁止提交真实值。本地开发请继续用 123123/.env（默认 BIND_HOST/CORS 不变）。

# ---- 网络加固（生产必改）----
BIND_HOST=127.0.0.1
CORS_ALLOW_ORIGIN=https://YOUR_DOMAIN
# 网关监听端口由 start_web.py 固定 8000；对外只经 Nginx 80/443

# ---- Supabase（内网自建后改为内网 URL）----
SUPABASE_URL=http://127.0.0.1:8001
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- 接口 Token（openssl rand -hex 32）----
MLOPS_TOKEN=
ANNOTATION_UPLOAD_TOKEN=
DATASET_UPLOAD_TOKEN=

ANNOTATION_STORAGE_BUCKET=annotations
MAX_UPLOAD_BYTES=209715200
MAX_DATASET_BYTES=53687091200
DATASET_CHUNK_SIZE=8388608
ALLOWED_UPLOAD_EXTENSIONS=.jpg,.jpeg,.png,.bmp,.webp,.gif,.txt,.xml,.csv,.json,.yaml,.yml,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.zip
DATASET_ALLOWED_EXTENSIONS=.csv,.tsv,.json,.xml,.zip,.jpg,.jpeg,.png,.bmp,.webp,.xlsx,.xls,.txt,.yaml,.yml,.pdf

# ---- 存储：生产推荐 minio ----
SHARED_STORAGE_BACKEND=minio
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=team-shared
MINIO_SECURE=false
MINIO_REGION=us-east-1
# 预签名有效期（秒）
MINIO_PRESIGN_EXPIRE=600
# 对外暴露给浏览器的上传前缀（经 Nginx /minio-upload/ 反代）
MINIO_PUBLIC_UPLOAD_PREFIX=https://YOUR_DOMAIN/minio-upload

LOG_LEVEL=INFO

# 百度 OCR（可选）
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# ---- 备份脚本环境（可由 cron 前 Environment 注入，或 source 本文件）----
# BACKUP_ROOT=/data/backups
# BACKUP_KEEP_DAYS=7
# BACKUP_UPLOADS=1
# BACKUP_MC_SRC=local/team-shared
# BACKUP_MC_DST=offsite/team-shared-backup
# BACKUP_PG_URL=postgresql://postgres:xxx@127.0.0.1:5432/postgres
# BACKUP_ENCRYPT_KEY_FILE=/opt/citysafe/backup.key
# BACKUP_OFFSITE_RSYNC=backup@offsite:/backups/citysafe/
# HEALTH_WEBHOOK_URL=
# DISK_ALERT_MOUNT=/data
# DISK_ALERT_THRESHOLD=85
