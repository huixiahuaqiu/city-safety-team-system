java
运行
@Component
public class LogCleanTask {
    @Autowired
    private SysOperationLogService logService;

    // 每天凌晨3点执行，清理超过90天的日志
    @Scheduled(cron = "0 0 3 * * ?")
    public void cleanExpiredLog() {
        logService.cleanExpired(90);
    }
