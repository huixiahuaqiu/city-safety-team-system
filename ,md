三、后端完整代码实现
3.1 自定义日志注解 @Log
放在需要记录日志的接口上，自动触发 AOP 采集。
java
运行
/**
 * 操作日志注解
 */
@Target(ElementType.METHOD)
@Retention(RetentionPolicy.RUNTIME)
@Documented
public @interface Log {
    /**
     * 操作模块
     */
    String module() default "";

    /**
     * 操作类型
     */
    String type() default "其他";

    /**
     * 操作描述
     */
    String desc() default "";

    /**
     * 是否保存请求参数
     */
    boolean saveRequest() default true;

    /**
     * 是否保存返回结果
     */
    boolean saveResponse() default true;
}
3.2 AOP 日志切面 LogAspect.java
核心逻辑，自动拦截带 @Log 注解的接口，采集信息并异步保存。
java
运行
@Aspect
@Component
@Slf4j
public class LogAspect {

    @Autowired
    private SysOperationLogService logService;

    /**
     * 切入点：所有带@Log注解的方法
     */
    @Pointcut("@annotation(com.yourproject.common.annotation.Log)")
    public void logPointCut() {}

    /**
     * 环绕通知
     */
    @Around("logPointCut()")
    public Object around(ProceedingJoinPoint point) throws Throwable {
        long startTime = System.currentTimeMillis();
        Object result = null;
        Exception exception = null;

        try {
            // 执行原方法
            result = point.proceed();
            return result;
        } catch (Exception e) {
            exception = e;
            throw e;
        } finally {
            // 方法执行完后，异步记录日志
            try {
                Log logAnnotation = getAnnotation(point);
                SysOperationLog operationLog = buildLog(point, logAnnotation, startTime, result, exception);
                // 异步保存，不阻塞主线程
                CompletableFuture.runAsync(() -> logService.saveLog(operationLog));
            } catch (Exception e) {
                log.error("记录操作日志失败", e);
            }
        }
    }

    /**
     * 获取注解
     */
    private Log getAnnotation(ProceedingJoinPoint point) {
        MethodSignature signature = (MethodSignature) point.getSignature();
        return signature.getMethod().getAnnotation(Log.class);
    }

    /**
     * 构建日志对象
     */
    private SysOperationLog buildLog(ProceedingJoinPoint point, Log logAnnotation,
                                     long startTime, Object result, Exception exception) {
        SysOperationLog operLog = new SysOperationLog();

        // 1. 注解基础信息
        operLog.setModule(logAnnotation.module());
        operLog.setOperationType(logAnnotation.type());
        operLog.setOperationDesc(logAnnotation.desc());

        // 2. 请求信息
        HttpServletRequest request = ServletUtils.getRequest();
        operLog.setRequestMethod(request.getMethod());
        operLog.setRequestUrl(request.getRequestURI());
        operLog.setIpAddress(IpUtils.getIpAddr(request));
        operLog.setBrowser(UserAgentUtils.getBrowser(request));
        operLog.setOs(UserAgentUtils.getOs(request));

        // 3. 操作人信息（从登录上下文获取）
        Long userId = SecurityUtils.getCurrentUserId();
        String userName = SecurityUtils.getCurrentUserName();
        operLog.setOperatorId(userId);
        operLog.setOperatorName(userName);

        // 4. 请求参数（脱敏处理）
        if (logAnnotation.saveRequest()) {
            String params = JSON.toJSONString(point.getArgs());
            // 密码等敏感字段脱敏
            params = SensitiveUtils.desensitize(params);
            operLog.setRequestParams(params);
        }

        // 5. 返回结果
        if (logAnnotation.saveResponse() && result != null) {
            operLog.setResponseResult(JSON.toJSONString(result));
        }

        // 6. 状态与异常
        if (exception != null) {
            operLog.setStatus(0);
            operLog.setErrorMsg(exception.getMessage());
        } else {
            operLog.setStatus(1);
        }

        // 7. 耗时
        operLog.setCostTime(System.currentTimeMillis() - startTime);
        operLog.setOperationTime(new Date());

        return operLog;
    }
}
3.3 服务层实现 SysOperationLogService.java
java
运行
@Service
public class SysOperationLogService {

    @Autowired
    private SysOperationLogMapper logMapper;

    /**
     * 保存日志
     */
    public void saveLog(SysOperationLog log) {
        logMapper.insert(log);
    }

    /**
     * 分页查询日志列表
     */
    public PageResult<SysOperationLog> getLogPage(LogQuery query) {
        Page<SysOperationLog> page = logMapper.selectPage(
                query.buildPage(),
                Wrappers.<SysOperationLog>lambdaQuery()
                        .like(StrUtil.isNotBlank(query.getModule()), SysOperationLog::getModule, query.getModule())
                        .like(StrUtil.isNotBlank(query.getOperatorName()), SysOperationLog::getOperatorName, query.getOperatorName())
                        .eq(query.getStatus() != null, SysOperationLog::getStatus, query.getStatus())
                        .ge(query.getStartTime() != null, SysOperationLog::getOperationTime, query.getStartTime())
                        .le(query.getEndTime() != null, SysOperationLog::getOperationTime, query.getEndTime())
                        .orderByDesc(SysOperationLog::getOperationTime)
        );
        return PageResult.of(page);
    }

    /**
     * 批量删除日志
     */
    @Transactional(rollbackFor = Exception.class)
    public void batchDelete(List<Long> ids) {
        logMapper.deleteBatchIds(ids);
    }

    /**
     * 清空全部日志
     */
    @Transactional(rollbackFor = Exception.class)
    public void cleanAll() {
        logMapper.delete(null);
    }

    /**
     * 清理过期日志（保留指定天数）
     */
    @Transactional(rollbackFor = Exception.class)
    public void cleanExpired(int keepDays) {
        Date expireDate = DateUtil.offsetDay(new Date(), -keepDays);
        logMapper.delete(Wrappers.<SysOperationLog>lambdaQuery()
                .lt(SysOperationLog::getOperationTime, expireDate));
    }
}
3.4 控制器 SysOperationLogController.java
java
运行
@RestController
@RequestMapping("/system/operation-log")
@PreAuthorize("hasRole('admin')")
@Tag(name = "操作日志管理")
public class SysOperationLogController {

    @Autowired
    private SysOperationLogService logService;

    @GetMapping("/list")
    @Operation(summary = "分页查询操作日志")
    public Result<PageResult<SysOperationLog>> list(LogQuery query) {
        return Result.success(logService.getLogPage(query));
    }

    @GetMapping("/{id}")
    @Operation(summary = "获取日志详情")
    public Result<SysOperationLog> getDetail(@PathVariable Long id) {
        return Result.success(logService.getById(id));
    }

    @DeleteMapping("/batch")
    @Operation(summary = "批量删除日志")
    @Log(module = "系统设置", type = "删除", desc = "批量删除操作日志")
    public Result<Void> batchDelete(@RequestBody List<Long> ids) {
        logService.batchDelete(ids);
        return Result.success();
    }

    @DeleteMapping("/clean")
    @Operation(summary = "清空全部日志")
    @Log(module = "系统设置", type = "删除", desc = "清空全部操作日志")
    public Result<Void> cleanAll() {
        logService.cleanAll();
        return Result.success();
    }

    @GetMapping("/export")
    @Operation(summary = "导出日志Excel")
    @Log(module = "系统设置", type = "导出", desc = "导出操作日志")
    public void export(LogQuery query, HttpServletResponse response) {
        // 用EasyExcel导出，逻辑同成员档案导出
        List<SysOperationLog> list = logService.getAll(query);
        EasyExcel.write(response.getOutputStream(), SysOperationLog.class)
                .sheet("操作日志")
                .doWrite(list);
    }
}
