<script setup>
import { ref, reactive, onMounted } from 'vue'
import { ElMessage, ElMessageBox } from 'element-plus'
import { Document, Search, Download } from '@element-plus/icons-vue'
import {
  getLogList,
  getLogDetail,
  batchDeleteLog,
  cleanAllLog,
  exportLog
} from '@/api/operationLog'

const loading = ref(false)
const tableData = ref([])
const total = ref(0)
const selectedIds = ref([])

const queryForm = reactive({
  pageNum: 1,
  pageSize: 10,
  module: '',
  operatorName: '',
  status: null,
  dateRange: []
})

// 详情弹窗
const detailDialogVisible = ref(false)
const detailData = ref({})

// 格式化JSON
const formatJson = (str) => {
  if (!str) return '-'
  try {
    return JSON.stringify(JSON.parse(str), null, 2)
  } catch {
    return str
  }
}

// 获取列表
const fetchList = async () => {
  loading.value = true
  const params = { ...queryForm }
  if (params.dateRange && params.dateRange.length === 2) {
    params.startTime = params.dateRange[0]
    params.endTime = params.dateRange[1]
  }
  delete params.dateRange
  try {
    const res = await getLogList(params)
    tableData.value = res.data.records
    total.value = res.data.total
  } finally {
    loading.value = false
  }
}

// 查询
const handleQuery = () => {
  queryForm.pageNum = 1
  fetchList()
}

// 重置
const resetQuery = () => {
  Object.assign(queryForm, {
    pageNum: 1,
    pageSize: 10,
    module: '',
    operatorName: '',
    status: null,
    dateRange: []
  })
  fetchList()
}

// 多选
const handleSelectionChange = (selection) => {
  selectedIds.value = selection.map(item => item.id)
}

// 批量删除
const handleBatchDelete = () => {
  ElMessageBox.confirm(`确定删除选中的 ${selectedIds.value.length} 条日志？`, '提示', {
    type: 'warning'
  }).then(async () => {
    await batchDeleteLog(selectedIds.value)
    ElMessage.success('删除成功')
    fetchList()
  })
}

// 清空全部
const handleCleanAll = () => {
  ElMessageBox.confirm('确定清空全部操作日志？清空后不可恢复！', '警告', {
    type: 'error'
  }).then(async () => {
    await cleanAllLog()
    ElMessage.success('已清空全部日志')
    fetchList()
  })
}

// 导出
const handleExport = async () => {
  const params = { ...queryForm }
  delete params.pageNum
  delete params.pageSize
  const res = await exportLog(params)
  const blob = new Blob([res])
  const url = URL.createObjectURL(blob)
  const a = document.createElement('a')
  a.href = url
  a.download = `操作日志_${new Date().getTime()}.xlsx`
  a.click()
  URL.revokeObjectURL(url)
}

// 打开详情
const openDetail = async (row) => {
  const res = await getLogDetail(row.id)
  detailData.value = res.data
  detailDialogVisible.value = true
}

onMounted(() => {
  fetchList()
})
</script>

