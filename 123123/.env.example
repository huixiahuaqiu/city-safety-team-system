# 本文件只提交占位符。部署时复制为 .env 并填写真实值，禁止提交 .env。

# 服务端 Supabase 同步。若为空，服务端 MLOps 云同步自动禁用。
SUPABASE_URL=
SUPABASE_KEY=

# MLOps 上报写接口 token。必须配置，否则 /api/mlops/report 拒绝写入。
MLOPS_TOKEN=

# 标注真实文件上传 token。必须配置，并与 config.local.js 中保持一致。
ANNOTATION_UPLOAD_TOKEN=

# 标注云端共享桶名称（需先执行 supabase_annotations_storage.sql）
ANNOTATION_STORAGE_BUCKET=annotations

# 单文件上传上限，默认 200MB。
MAX_UPLOAD_BYTES=209715200

# 允许上传的扩展名，按业务需要收敛。
ALLOWED_UPLOAD_EXTENSIONS=.jpg,.jpeg,.png,.bmp,.webp,.gif,.txt,.xml,.csv,.json,.yaml,.yml

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 百度 OCR（文档/专利证书识别用，server.cjs / proxy_server.js）。
# 在百度智能云控制台申请，禁止提交真实值。
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
