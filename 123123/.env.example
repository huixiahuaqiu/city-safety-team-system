# 本文件只提交占位符。部署时复制为 .env 并填写真实值，禁止提交 .env。

# 服务端 Supabase 同步。若为空，服务端 MLOps 云同步自动禁用。
SUPABASE_URL=
SUPABASE_KEY=

# MLOps 上报写接口 token。必须配置，否则 /api/mlops/report 拒绝写入。
MLOPS_TOKEN=

# 标注真实文件上传 token。必须配置，并与 config.local.js 中保持一致。
ANNOTATION_UPLOAD_TOKEN=

# 数据集分片上传 token。留空则本机网关允许上传；生产环境建议配置。
# 也可复用 ANNOTATION_UPLOAD_TOKEN（服务端会自动回退）。
DATASET_UPLOAD_TOKEN=

# 标注云端共享桶名称（需先执行 supabase_annotations_storage.sql）
ANNOTATION_STORAGE_BUCKET=annotations

# 单文件上传上限，默认 200MB（标注接口）。
MAX_UPLOAD_BYTES=209715200

# 数据集单文件上限，默认 10GB。
MAX_DATASET_BYTES=10737418240

# 数据集分片大小，默认 2MB。
DATASET_CHUNK_SIZE=2097152

# 允许上传的扩展名，按业务需要收敛。
ALLOWED_UPLOAD_EXTENSIONS=.jpg,.jpeg,.png,.bmp,.webp,.gif,.txt,.xml,.csv,.json,.yaml,.yml

# 数据集允许扩展名
DATASET_ALLOWED_EXTENSIONS=.csv,.tsv,.json,.xml,.zip,.jpg,.jpeg,.png,.bmp,.webp,.xlsx,.xls,.txt,.yaml,.yml

# 团队共享文件存储后端：local（默认磁盘）或 minio（S3 兼容对象存储）
SHARED_STORAGE_BACKEND=local

# MinIO / S3 兼容配置（仅当 SHARED_STORAGE_BACKEND=minio 时生效）
# 需安装：pip install minio
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=team-shared
MINIO_SECURE=false
MINIO_REGION=us-east-1

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 百度 OCR（文档/专利证书识别用，server.cjs / proxy_server.js）。
# 在百度智能云控制台申请，禁止提交真实值。
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
