                const keyWords = nameWords.filter(word => word.length > 2);
                
                analysisContent.summary = `本专利涉及${keyWords.join('、')}等相关技术，通过创新的技术方案解决了现有技术中的关键问题，具有重要的技术价值和广阔的应用前景。`;
                analysisContent.keyTechPoints = [
                    `${keyWords[0]}核心技术`,
