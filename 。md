二、数据库详细设计（2 张核心表）
2.1 备份记录表 sys_backup_record
sql
CREATE TABLE `sys_backup_record` (
  `id` bigint NOT NULL AUTO_INCREMENT COMMENT '主键ID',
  `backup_name` varchar(200) NOT NULL COMMENT '备份名称',
  `backup_type` tinyint NOT NULL COMMENT '备份类型：1-仅数据库 2-全量备份',
  `backup_way` tinyint NOT NULL COMMENT '备份方式：1-手动备份 2-自动备份',
  `file_size` bigint DEFAULT 0 COMMENT '文件大小，单位：字节',
  `file_path` varchar(500) DEFAULT NULL COMMENT '服务器绝对存储路径',
  `file_md5` varchar(64) DEFAULT NULL COMMENT '文件MD5校验值，用于完整性校验',
  `db_version` varchar(50) DEFAULT NULL COMMENT '备份时数据库版本号',
  `status` tinyint DEFAULT 0 COMMENT '状态：0-进行中 1-成功 2-失败',
  `error_msg` varchar(1000) DEFAULT NULL COMMENT '失败原因详情',
  `operator_id` bigint DEFAULT NULL COMMENT '操作人ID',
  `operator_name` varchar(50) DEFAULT NULL COMMENT '操作人姓名',
  `remark` varchar(500) DEFAULT NULL COMMENT '备注',
  `create_time` datetime DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
  `update_time` datetime DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP COMMENT '更新时间',
  `is_deleted` tinyint DEFAULT 0 COMMENT '软删除：0-未删 1-已删',
  PRIMARY KEY (`id`),
  KEY `idx_status` (`status`),
  KEY `idx_create_time` (`create_time`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COMMENT='数据备份记录表';
2.2 自动备份配置表 sys_backup_config
