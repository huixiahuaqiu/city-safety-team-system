<script setup>
import { ref, onMounted } from 'vue'
import { ElMessage, ElMessageBox } from 'element-plus'
import { DataLine, Download, Setting } from '@element-plus/icons-vue'
import {
  manualBackup,
  getBackupList,
  deleteBackup,
  restoreBackup,
  getBackupConfig,
  updateBackupConfig
} from '@/api/backup'

const loading = ref(false)
const backingUp = ref(false)
const restoring = ref(false)
const tableData = ref([])
const total = ref(0)
const query = ref({
  pageNum: 1,
  pageSize: 10
})

// 恢复弹窗
const restoreDialogVisible = ref(false)
const currentRestoreRow = ref({})
const restoreForm = ref({ adminPassword: '' })

// 配置弹窗
const configDialogVisible = ref(false)
const configForm = ref({})

// 格式化文件大小
const formatSize = (bytes) => {
  if (!bytes) return '0 B'
  const units = ['B', 'KB', 'MB', 'GB']
  let index = 0
  let size = bytes
  while (size >= 1024 && index < units.length - 1) {
    size /= 1024
    index++
  }
  return size.toFixed(2) + ' ' + units[index]
}

// 获取列表
const fetchList = async () => {
  loading.value = true
  try {
    const res = await getBackupList(query.value)
    tableData.value = res.data.records
    total.value = res.data.total
  } finally {
    loading.value = false
  }
}

// 执行备份
const handleBackup = async (type) => {
  backingUp.value = true
  try {
    await manualBackup(type)
    ElMessage.success('备份任务已提交，后台执行中')
    // 轮询刷新列表
    const timer = setInterval(() => {
      fetchList().then(() => {
        const hasRunning = tableData.value.some(item => item.status === 0)
        if (!hasRunning) clearInterval(timer)
      })
    }, 3000)
  } finally {
    backingUp.value = false
  }
}

// 下载
const handleDownload = (id) => {
  window.open(`/system/backup/download/${id}`, '_blank')
}

// 删除
const handleDelete = (id) => {
  ElMessageBox.confirm('确定删除该备份文件？删除后不可恢复', '提示', {
    type: 'warning'
  }).then(async () => {
    await deleteBackup(id)
    ElMessage.success('删除成功')
    fetchList()
  })
}

// 打开恢复弹窗
const openRestoreDialog = (row) => {
  currentRestoreRow.value = row
  restoreForm.value.adminPassword = ''
  restoreDialogVisible.value = true
}

// 确认恢复
const confirmRestore = async () => {
  if (!restoreForm.value.adminPassword) {
    ElMessage.warning('请输入管理员密码')
    return
  }
  restoring.value = true
  try {
    await restoreBackup({
      backupId: currentRestoreRow.value.id,
      adminPassword: restoreForm.value.adminPassword
    })
    ElMessage.success('恢复成功，请重新登录')
    restoreDialogVisible.value = false
    // 退出登录逻辑
    // logout()
  } finally {
    restoring.value = false
  }
}

// 打开配置弹窗
const openConfigDialog = async () => {
  const res = await getBackupConfig()
  configForm.value = res.data
  configDialogVisible.value = true
}

// 保存配置
const saveConfig = async () => {
  await updateBackupConfig(configForm.value)
  ElMessage.success('配置保存成功')
  configDialogVisible.value = false
}

onMounted(() => {
  fetchList()
})
</script>

