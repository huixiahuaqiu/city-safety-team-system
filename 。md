@RestController
@RequestMapping("/system/backup")
@PreAuthorize("hasRole('admin')") // 全局权限拦截，仅管理员可访问
@Tag(name = "数据备份管理")
public class BackupController {

    @Autowired
    private BackupService backupService;
    @Autowired
    private SysBackupRecordMapper backupRecordMapper;
    @Autowired
    private SysBackupConfigMapper backupConfigMapper;

    @PostMapping("/manual")
    @Operation(summary = "执行手动备份")
    public Result<Long> manualBackup(@RequestParam Integer backupType) {
        // 从登录上下文获取当前用户ID和姓名，示例：
        Long userId = SecurityUtils.getCurrentUserId();
        String userName = SecurityUtils.getCurrentUserName();
        Long id = backupService.doManualBackup(backupType, userId, userName);
        return Result.success(id);
    }

    @GetMapping("/list")
    @Operation(summary = "分页查询备份记录")
    public Result<PageResult<SysBackupRecord>> list(PageQuery query) {
        Page<SysBackupRecord> page = backupRecordMapper.selectPage(
                query.buildPage(),
                Wrappers.<SysBackupRecord>lambdaQuery()
                        .eq(SysBackupRecord::getIsDeleted, 0)
                        .orderByDesc(SysBackupRecord::getCreateTime)
        );
        return Result.success(PageResult.of(page));
    }

    @GetMapping("/download/{id}")
    @Operation(summary = "下载备份文件")
    public void download(@PathVariable Long id, HttpServletResponse response) throws IOException {
        SysBackupRecord record = backupRecordMapper.selectById(id);
        if (record == null || record.getStatus() != 1) {
            throw new RuntimeException("备份文件不可下载");
        }
        File file = new File(record.getFilePath());
        if (!file.exists()) throw new RuntimeException("文件已丢失");

        response.setContentType("application/octet-stream");
        response.setHeader("Content-Disposition", 
                "attachment;filename=" + URLEncoder.encode(record.getBackupName() + ".zip", StandardCharsets.UTF_8));
        FileUtil.writeToStream(file, response.getOutputStream());
    }

    @PostMapping("/restore")
    @Operation(summary = "执行数据恢复")
    public Result<Void> restore(@RequestParam Long backupId, @RequestParam String adminPassword) {
        Long userId = SecurityUtils.getCurrentUserId();
        backupService.doRestore(backupId, userId, adminPassword);
        return Result.success();
    }

    @DeleteMapping("/{id}")
    @Operation(summary = "删除备份")
    public Result<Void> delete(@PathVariable Long id) {
        backupService.deleteBackup(id);
        return Result.success();
    }

    @GetMapping("/config")
    @Operation(summary = "获取自动备份配置")
    public Result<SysBackupConfig> getConfig() {
        return Result.success(backupConfigMapper.selectById(1));
    }

    @PutMapping("/config")
    @Operation(summary = "更新自动备份配置")
    public Result<Void> updateConfig(@RequestBody SysBackupConfig config) {
        config.setId(1L);
        backupConfigMapper.updateById(config);
        return Result.success();
    }
}
3.7 自动备份定时任务 BackupTask.java
java
运行
@Component
@Slf4j
public class BackupTask {

    @Autowired
    private BackupService backupService;
    @Autowired
    private SysBackupConfigMapper backupConfigMapper;

    /**
     * 每分钟检查一次是否需要执行自动备份
     */
    @Scheduled(cron = "0 * * * * ?")
    public void autoBackupCheck() {
        SysBackupConfig config = backupConfigMapper.selectById(1);
        if (config.getEnableAuto() == 0) return;

        // 判断当前时间是否匹配执行时间
        String nowTime = DateUtil.format(new Date(), "HH:mm");
        if (!nowTime.equals(config.getExecuteTime())) return;

        // 判断周期是否匹配
        int cycle = config.getBackupCycle();
        Date now = new Date();
        boolean execute = false;
        if (cycle == 1) {
            execute = true; // 每天执行
        } else if (cycle == 2) {
            // 每周一执行（可配置，默认周一）
            execute = DateUtil.dayOfWeek(now) == 1;
        } else if (cycle == 3) {
            // 每月1号执行
            execute = DateUtil.dayOfMonth(now) == 1;
        }

        if (execute) {
            log.info("开始执行自动备份");
            try {
                backupService.doManualBackup(config.getBackupType(), 0L, "系统自动备份");
                // 清理过期备份
                backupService.cleanExpiredBackup(config.getSaveCount());
                log.info("自动备份执行完成");
            } catch (Exception e) {
                log.error("自动备份失败", e);
            }
        }
    }
}
