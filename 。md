3.4 核心工具类 BackupUtil.java（最关键）
java
运行
@Component
@Slf4j
public class BackupUtil {

    @Autowired
    private BackupProperties backupProperties;

    /**
     * 备份数据库，返回生成的SQL文件路径
     */
    public String backupDatabase(String fileName) throws Exception {
        // 1. 创建存储目录
        File storeDir = new File(backupProperties.getStoreRootPath());
        if (!storeDir.exists()) storeDir.mkdirs();
        
        String sqlFilePath = backupProperties.getStoreRootPath() + fileName + ".sql";
        File sqlFile = new File(sqlFilePath);
        
        // 2. 构建mysqldump命令
        List<String> command = new ArrayList<>();
        command.add(backupProperties.getMysqldumpPath());
        command.add("-u" + backupProperties.getDbUsername());
        command.add("-p" + backupProperties.getDbPassword());
        command.add("--default-character-set=utf8mb4");
        command.add("--single-transaction");
        command.add("--routines");
        command.add("--triggers");
        command.add(backupProperties.getDatabaseName());
        command.add("-e");
        command.add("source " + sqlFilePath); // 输出到文件

        // 3. 执行命令
        ProcessBuilder processBuilder = new ProcessBuilder(command);
        processBuilder.redirectErrorStream(true);
        Process process = processBuilder.start();
        
        // 读取输出，防止缓冲区满导致进程卡死
        try (BufferedReader reader = new BufferedReader(
                new InputStreamReader(process.getInputStream(), StandardCharsets.UTF_8))) {
            String line;
            while ((line = reader.readLine()) != null) {
                log.info("mysqldump输出: {}", line);
            }
        }
        
        int exitCode = process.waitFor();
        if (exitCode != 0) {
            throw new RuntimeException("数据库备份失败，进程退出码：" + exitCode);
        }
        
        // 4. 校验文件
        if (!sqlFile.exists() || sqlFile.length() == 0) {
            throw new RuntimeException("数据库备份失败，生成文件为空");
        }
        
        return sqlFilePath;
    }

    /**
     * 恢复数据库
     */
    public void restoreDatabase(String sqlFilePath) throws Exception {
        File sqlFile = new File(sqlFilePath);
        if (!sqlFile.exists()) throw new RuntimeException("SQL文件不存在");

        // 1. 构建mysql恢复命令
        List<String> command = new ArrayList<>();
        command.add(backupProperties.getMysqldumpPath().replace("mysqldump", "mysql"));
        command.add("-u" + backupProperties.getDbUsername());
        command.add("-p" + backupProperties.getDbPassword());
        command.add("--default-character-set=utf8mb4");
        command.add(backupProperties.getDatabaseName());
        command.add("-e");
        command.add("source " + sqlFilePath);

        // 2. 执行命令
        ProcessBuilder processBuilder = new ProcessBuilder(command);
        processBuilder.redirectErrorStream(true);
        Process process = processBuilder.start();

        try (BufferedReader reader = new BufferedReader(
                new InputStreamReader(process.getInputStream(), StandardCharsets.UTF_8))) {
            String line;
            while ((line = reader.readLine()) != null) {
                log.info("mysql恢复输出: {}", line);
            }
        }

        int exitCode = process.waitFor();
        if (exitCode != 0) {
            throw new RuntimeException("数据库恢复失败，进程退出码：" + exitCode);
        }
    }

    /**
     * 打包上传目录为ZIP，返回压缩包路径
     */
    public String zipUploadFiles(String zipFileName) {
        String zipPath = backupProperties.getStoreRootPath() + zipFileName + "_files.zip";
        ZipUtil.zip(backupProperties.getUploadRootPath(), zipPath);
        return zipPath;
    }

    /**
     * 解压附件ZIP到上传目录
     */
    public void unzipUploadFiles(String zipPath) {
        File zipFile = new File(zipPath);
        if (!zipFile.exists()) throw new RuntimeException("附件压缩包不存在");
        // 先清空原上传目录（可选，建议先备份原目录）
        ZipUtil.unzip(zipPath, backupProperties.getUploadRootPath());
    }

    /**
     * 计算文件MD5，用于完整性校验
     */
    public String getFileMd5(String filePath) {
        return MD5.create().digestHex(new File(filePath));
    }

    /**
     * 生成备份文件名：backup_类型_年月日时分秒
     */
    public String generateBackupName(Integer type) {
        String typeStr = type == 1 ? "db" : "full";
        return "backup_" + typeStr + "_" + DateUtil.format(new Date(), "yyyyMMddHHmmss");
    }
}
3.5 服务层实现 BackupService.java
java
运行
@Service
@Slf4j
public class BackupService {

    @Autowired
    private BackupUtil backupUtil;
    @Autowired
    private BackupProperties backupProperties;
    @Autowired
    private SysBackupRecordMapper backupRecordMapper;
    @Autowired
    private SysBackupConfigMapper backupConfigMapper;

    /**
     * 执行手动备份
     * @param backupType 1-仅数据库 2-全量
     */
    @Transactional(rollbackFor = Exception.class)
    public Long doManualBackup(Integer backupType, Long operatorId, String operatorName) {
        // 1. 插入备份记录（状态：进行中）
        SysBackupRecord record = new SysBackupRecord();
        String backupName = backupUtil.generateBackupName(backupType);
        record.setBackupName(backupName);
        record.setBackupType(backupType);
        record.setBackupWay(1); // 手动
        record.setStatus(0);
        record.setOperatorId(operatorId);
        record.setOperatorName(operatorName);
        backupRecordMapper.insert(record);

        // 2. 异步执行备份（避免前端超时）
        CompletableFuture.runAsync(() -> {
            try {
                executeBackup(record);
                record.setStatus(1);
            } catch (Exception e) {
                log.error("备份失败", e);
                record.setStatus(2);
                record.setErrorMsg(e.getMessage());
            } finally {
                backupRecordMapper.updateById(record);
            }
        });

        return record.getId();
    }

    /**
     * 执行备份核心逻辑
     */
    private void executeBackup(SysBackupRecord record) throws Exception {
        String backupName = record.getBackupName();
        Integer backupType = record.getBackupType();
        String finalFilePath;

        if (backupType == 1) {
            // 仅数据库备份
            finalFilePath = backupUtil.backupDatabase(backupName);
        } else {
            // 全量备份：数据库+附件 → 打包成一个ZIP
            String sqlPath = backupUtil.backupDatabase(backupName);
            String zipPath = backupUtil.zipUploadFiles(backupName);
            
            // 两个文件打包成最终全量包
            String fullZipPath = backupProperties.getStoreRootPath() + backupName + ".zip";
            List<String> files = Arrays.asList(sqlPath, zipPath);
            ZipUtil.zip(files, fullZipPath);
            
            // 删除临时SQL和附件包
            FileUtil.del(sqlPath);
            FileUtil.del(zipPath);
            finalFilePath = fullZipPath;
        }

        // 3. 填充文件信息
        File file = new File(finalFilePath);
        record.setFilePath(finalFilePath);
        record.setFileSize(file.length());
        record.setFileMd5(backupUtil.getFileMd5(finalFilePath));
    }

    /**
     * 执行数据恢复
     */
    @Transactional(rollbackFor = Exception.class)
    public void doRestore(Long backupId, Long operatorId, String operatorPassword) {
        // 1. 校验管理员密码（二次校验）
        // 此处调用你的用户服务，校验密码是否正确，示例：
        // if (!userService.checkPassword(operatorId, operatorPassword)) {
        //     throw new RuntimeException("管理员密码错误，无法执行恢复");
        // }

        // 2. 查询备份记录
        SysBackupRecord record = backupRecordMapper.selectById(backupId);
        if (record == null || record.getStatus() != 1) {
            throw new RuntimeException("备份记录不存在或备份失败，不可恢复");
        }

        // 3. 校验文件完整性
        String currentMd5 = backupUtil.getFileMd5(record.getFilePath());
        if (!currentMd5.equals(record.getFileMd5())) {
            throw new RuntimeException("备份文件已损坏，无法恢复");
        }

        // 4. 恢复前自动兜底备份（强烈建议开启）
        if (backupProperties.getAutoSafetyBackup()) {
            SysBackupRecord safetyRecord = new SysBackupRecord();
            String safetyName = "safety_restore_before_" + DateUtil.format(new Date(), "yyyyMMddHHmmss");
            safetyRecord.setBackupName(safetyName);
            safetyRecord.setBackupType(record.getBackupType());
            safetyRecord.setBackupWay(1);
            safetyRecord.setStatus(0);
            safetyRecord.setOperatorId(operatorId);
            safetyRecord.setRemark("恢复前自动兜底备份");
            backupRecordMapper.insert(safetyRecord);
            try {
                executeBackup(safetyRecord);
                safetyRecord.setStatus(1);
                backupRecordMapper.updateById(safetyRecord);
            } catch (Exception e) {
                throw new RuntimeException("兜底备份失败，已终止恢复操作：" + e.getMessage());
            }
        }

        // 5. 执行恢复
        try {
            if (record.getBackupType() == 1) {
                // 仅恢复数据库
                backupUtil.restoreDatabase(record.getFilePath());
            } else {
                // 全量恢复：先解压，再恢复数据库+附件
                String tempDir = backupProperties.getTempPath() + "restore_" + backupId + "/";
                ZipUtil.unzip(record.getFilePath(), tempDir);
                
                // 找到SQL文件和附件ZIP
                File tempDirFile = new File(tempDir);
                File sqlFile = Arrays.stream(tempDirFile.listFiles())
                        .filter(f -> f.getName().endsWith(".sql"))
                        .findFirst().orElseThrow(() -> new RuntimeException("备份包中无SQL文件"));
                File filesZip = Arrays.stream(tempDirFile.listFiles())
                        .filter(f -> f.getName().endsWith("_files.zip"))
                        .findFirst().orElseThrow(() -> new RuntimeException("备份包中无附件文件"));

                // 恢复数据库
                backupUtil.restoreDatabase(sqlFile.getAbsolutePath());
                // 恢复附件
                backupUtil.unzipUploadFiles(filesZip.getAbsolutePath());
                
                // 删除临时文件
                FileUtil.del(tempDir);
            }
            log.info("数据恢复成功，操作人：{}", operatorId);
        } catch (Exception e) {
            log.error("数据恢复失败", e);
            throw new RuntimeException("恢复失败：" + e.getMessage());
        }
    }

    /**
     * 删除备份记录+文件
     */
    @Transactional(rollbackFor = Exception.class)
    public void deleteBackup(Long id) {
        SysBackupRecord record = backupRecordMapper.selectById(id);
        if (record == null) return;
        
        // 删除服务器文件
        if (StrUtil.isNotBlank(record.getFilePath())) {
            FileUtil.del(record.getFilePath());
        }
        // 软删除记录
        record.setIsDeleted(1);
        backupRecordMapper.updateById(record);
    }

    /**
     * 清理过期备份（按保留份数）
     */
    public void cleanExpiredBackup(int saveCount) {
        List<SysBackupRecord> list = backupRecordMapper.selectList(
                Wrappers.<SysBackupRecord>lambdaQuery()
                        .eq(SysBackupRecord::getStatus, 1)
                        .eq(SysBackupRecord::getIsDeleted, 0)
                        .orderByDesc(SysBackupRecord::getCreateTime)
        );
        if (list.size() <= saveCount) return;
        
        // 删除超出份数的最早备份
        for (int i = saveCount; i < list.size(); i++) {
            deleteBackup(list.get(i).getId());
        }
    }
}
