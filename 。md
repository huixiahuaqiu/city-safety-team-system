CREATE TABLE `sys_backup_config` (
  `id` bigint NOT NULL AUTO_INCREMENT COMMENT '主键ID',
  `enable_auto` tinyint DEFAULT 0 COMMENT '是否开启自动备份：0-关闭 1-开启',
  `backup_cycle` tinyint DEFAULT 2 COMMENT '备份周期：1-每天 2-每周 3-每月',
  `execute_time` varchar(20) DEFAULT '02:00' COMMENT '执行时间，格式 HH:mm',
  `backup_type` tinyint DEFAULT 2 COMMENT '自动备份类型：1-仅数据库 2-全量',
