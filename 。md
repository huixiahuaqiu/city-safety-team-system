    url: '/system/backup/manual',
    method: 'post',
    params: { backupType }
  })
}

// 备份列表
export function getBackupList(params) {
  return request({
    url: '/system/backup/list',
    method: 'get',
    params
  })
}

// 删除备份
export function deleteBackup(id) {
  return request({
    url: `/system/backup/${id}`,
    method: 'delete'
  })
}

// 执行恢复
export function restoreBackup(data) {
  return request({
    url: '/system/backup/restore',
    method: 'post',
    data
  })
}

// 获取配置
export function getBackupConfig() {
  return request({
    url: '/system/backup/config',
    method: 'get'
  })
}

// 更新配置
export function updateBackupConfig(data) {
  return request({
    url: '/system/backup/config',
    method: 'put',
    data
  })
}
