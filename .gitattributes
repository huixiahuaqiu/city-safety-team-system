# ================================================
# Git 属性配置 - 统一团队换行符和文件处理
# ================================================

# 自动检测文本文件并规范化换行符
* text=auto

# 明确标记文本文件（确保换行符正确处理）
*.html text
*.css text
*.js text
*.cjs text
*.mjs text
*.json text
*.py text
*.md text
*.yml text
*.yaml text
*.txt text
*.xml text
*.sh text eol=lf

# 二进制文件不做处理
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.exe binary
*.dll binary
*.so binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
